---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Robot from "../components/Robot.astro";
import {
  siteConfig,
  homeContent,
  aboutContent,
  experienceContent,
  projectsContent,
  openSourceContent,
} from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "/favicon.svg"} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteConfig.title}</title>
    <meta name="description" content={siteConfig.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const initialTheme = savedTheme === "system" ? (prefersDark ? "dark" : "light") : savedTheme;
        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <style>
      * { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
      code, .font-mono { font-family: 'JetBrains Mono', monospace; }
      html { scroll-behavior: smooth; scroll-padding-top: 5rem; }
      body { margin: 0; overflow-x: hidden; }

      .dot-hexagon-light {
        background-image: radial-gradient(circle, #80808030 1px, transparent 1px),
          radial-gradient(circle, #80808030 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position: 0 0, 12px 20.78px;
      }
      .dot-hexagon-dark {
        background-image: radial-gradient(circle, #ffffff20 1px, transparent 1px),
          radial-gradient(circle, #ffffff20 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position: 0 0, 12px 20.78px;
      }

      /* Scroll reveal animations */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.revealed {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.2s; }
      .reveal-delay-3 { transition-delay: 0.3s; }
      .reveal-delay-4 { transition-delay: 0.4s; }
      .reveal-delay-5 { transition-delay: 0.5s; }

      /* Typing cursor */
      .typing-cursor::after {
        content: '|';
        animation: blink 1s step-end infinite;
        color: rgb(99 102 241);
        font-weight: 300;
      }
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      /* Gradient text */
      .gradient-text {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Skill card hover */
      .skill-card {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .skill-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(99, 102, 241, 0.15);
      }

      /* Project card — Gemini-inspired dark style */
      .project-card {
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .project-card:hover {
        transform: translateY(-6px);
        border-color: rgba(99, 102, 241, 0.3);
      }
      .project-card:hover .project-image {
        opacity: 1;
        transform: scale(1.05);
      }
      .project-image {
        transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* Section divider */
      .section-line {
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #6366f1, #8b5cf6);
        border-radius: 2px;
      }

      /* Blue accent for section titles */
      .title-accent {
        color: #6366f1;
      }
      :global(.dark) .title-accent {
        color: #818cf8;
      }
    </style>
  </head>
  <body class="min-h-screen bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100 transition-colors duration-300">
    <!-- Background pattern -->
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div class="absolute inset-0 dot-hexagon-light dark:dot-hexagon-dark"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.6)_60%,rgba(255,255,255,0.95)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(10,10,10,0.6)_60%,rgba(10,10,10,0.95)_85%,rgb(10,10,10)_100%)]"></div>
    </div>

    <Navigation />

    <main class="relative z-10">
      <!-- ═══════════════ HOME SECTION ═══════════════ -->
      <section id="home" class="min-h-screen flex items-center justify-center px-6 pt-16">
        <div class="max-w-6xl mx-auto w-full">
          <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-16">
            <!-- Left: Text -->
            <div class="w-full lg:w-1/2 text-center lg:text-left">
              <p class="text-sm font-mono font-medium text-indigo-600 dark:text-indigo-400 mb-3 tracking-wider uppercase reveal">
                &gt; {homeContent.greeting}
              </p>
              <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-4 reveal reveal-delay-1">
                <span class="gradient-text">{homeContent.name}</span>
              </h1>
              <p class="text-lg sm:text-xl font-medium text-neutral-500 dark:text-neutral-400 mb-6 reveal reveal-delay-2">
                <span class="typing-cursor">{homeContent.role}</span>
              </p>
              <p class="text-base sm:text-lg leading-relaxed text-neutral-600 dark:text-neutral-400 mb-8 max-w-xl mx-auto lg:mx-0 reveal reveal-delay-3">
                {homeContent.description}
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start reveal reveal-delay-4">
                <a
                  href={homeContent.buttons.about.href}
                  class="nav-link group inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-indigo-500/25"
                >
                  {homeContent.buttons.about.text}
                  <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
                <a
                  href={import.meta.env.BASE_URL + homeContent.buttons.cv.href}
                  download
                  class="group inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-neutral-700 dark:text-neutral-300 bg-white dark:bg-neutral-800 border-2 border-neutral-200 dark:border-neutral-700 rounded-xl hover:border-indigo-400 dark:hover:border-indigo-500 transition-all duration-300 hover:scale-105 hover:shadow-lg"
                >
                  {homeContent.buttons.cv.text}
                  <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" />
                  </svg>
                </a>
              </div>
              <!-- Social links -->
              <div class="flex gap-4 mt-8 justify-center lg:justify-start reveal reveal-delay-4">
                <a href={siteConfig.social.github} target="_blank" class="p-2 rounded-lg text-neutral-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.12 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                </a>
                <a href={siteConfig.social.linkedin} target="_blank" class="p-2 rounded-lg text-neutral-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
                </a>
                <a href={siteConfig.social.email} class="p-2 rounded-lg text-neutral-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-all">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </a>
              </div>
            </div>
            <!-- Right: Robot -->
            <div class="w-full lg:w-1/2 flex items-center justify-center reveal reveal-delay-2">
              <div class="w-64 sm:w-80 lg:w-96">
                <Robot />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════ ABOUT SECTION ═══════════════ -->
      <section id="about" class="py-24 sm:py-32 px-6">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-16">
            <div class="section-line mx-auto mb-4 reveal"></div>
            <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight reveal reveal-delay-1">
              About <span class="title-accent">Me</span>
            </h2>
            <p class="mt-3 text-lg text-neutral-500 dark:text-neutral-400 font-medium reveal reveal-delay-2">
              {aboutContent.tagline}
            </p>
          </div>

          <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center mb-20">
            <!-- Photo -->
            <div class="w-full lg:w-2/5 reveal">
              <div class="relative group">
                <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-2xl opacity-20 group-hover:opacity-30 blur-xl transition-opacity duration-500"></div>
                <img
                  src={import.meta.env.BASE_URL + aboutContent.image.src}
                  alt={aboutContent.image.alt}
                  class="relative w-full max-w-[380px] mx-auto aspect-square object-cover rounded-2xl shadow-xl"
                />
              </div>
            </div>
            <!-- Bio + Languages -->
            <div class="w-full lg:w-3/5 reveal reveal-delay-1">
              <ul class="space-y-3">
                {aboutContent.bio.map((point) => (
                  <li class="flex gap-3 text-base sm:text-lg leading-relaxed text-neutral-600 dark:text-neutral-400 [&>span>strong]:text-neutral-800 dark:[&>span>strong]:text-neutral-200 [&>span>strong]:font-semibold">
                    <span class="mt-2.5 w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-indigo-400 flex-shrink-0"></span>
                    <span set:html={point} />
                  </li>
                ))}
              </ul>

              <!-- Languages -->
              <div class="mt-6">
                <h4 class="text-xs font-medium uppercase tracking-wider text-neutral-400 dark:text-neutral-600 mb-2">Languages</h4>
                <div class="flex flex-wrap gap-2">
                  {aboutContent.languages.map((lang) => (
                    <div class="flex items-center gap-1.5 px-3 py-1 rounded-lg border border-neutral-200 dark:border-neutral-800">
                      <span class="text-xs text-neutral-500 dark:text-neutral-500">{lang.name}</span>
                      <span class="text-[10px] text-neutral-400 dark:text-neutral-600 bg-neutral-100 dark:bg-neutral-800/50 px-1.5 py-0.5 rounded">{lang.level}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Skills Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {aboutContent.skillCategories.map((category, i) => (
              <div class={`skill-card p-6 rounded-2xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 shadow-sm reveal reveal-delay-${i + 1}`}>
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
                    {category.icon === "code" && (
                      <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                      </svg>
                    )}
                    {category.icon === "server" && (
                      <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                      </svg>
                    )}
                    {category.icon === "wrench" && (
                      <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    )}
                    {category.icon === "shield" && (
                      <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                    )}
                  </div>
                  <h3 class="font-bold text-neutral-900 dark:text-neutral-100">{category.title}</h3>
                </div>
                <ul class="space-y-2">
                  {category.skills.map((skill) => (
                    <li class="flex items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                      <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-indigo-400 flex-shrink-0"></span>
                      {skill}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ EXPERIENCE SECTION ═══════════════ -->
      <section id="experience" class="py-24 sm:py-32 px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-16">
            <div class="section-line mx-auto mb-4 reveal"></div>
            <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight reveal reveal-delay-1">
              My <span class="title-accent">Experience</span>
            </h2>
            <p class="mt-3 text-lg text-neutral-500 dark:text-neutral-400 reveal reveal-delay-2">
              {experienceContent.subtitle}
            </p>
          </div>

          <!-- Work Experience -->
          <div class="mb-16">
            <div class="flex items-center gap-3 mb-8 reveal">
              <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
                <!-- Briefcase icon -->
                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Work</h3>
            </div>

            <div class="relative">
              <!-- Timeline line -->
              <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500 via-purple-500 to-transparent"></div>

              <div class="space-y-10">
                {experienceContent.work.map((item, i) => (
                  <div class={`relative pl-14 reveal reveal-delay-${i + 1}`}>
                    <!-- Timeline dot -->
                    <div class="absolute left-0 top-1">
                      <div class="w-10 h-10 rounded-full bg-neutral-200 dark:bg-neutral-700 ring-4 ring-white dark:ring-neutral-950 shadow-sm flex items-center justify-center">
                        <svg class="w-4 h-4 text-neutral-500 dark:text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                      </div>
                    </div>

                    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                        <div>
                          <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
                            {item.position}
                          </h3>
                          <p class="text-indigo-600 dark:text-indigo-400 font-semibold flex items-center gap-2">
                            <img src={item.logo} alt={item.company} class="w-4 h-4 object-contain rounded-sm" referrerpolicy="no-referrer" />
                            {item.company}
                          </p>
                        </div>
                        <span class="text-xs font-mono font-medium text-neutral-500 dark:text-neutral-400 tracking-wider whitespace-nowrap bg-neutral-100 dark:bg-neutral-800 px-3 py-1.5 rounded-full self-start flex items-center gap-1.5">
                          <svg class="w-3 h-3 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/><path d="M16 2v4M8 2v4M3 10h18" stroke-width="2" stroke-linecap="round"/></svg>
                          {item.period}
                        </span>
                      </div>

                      <ul class="space-y-3">
                        {item.bullets.map((bullet) => (
                          <li class="flex gap-3 text-sm sm:text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
                            <span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-500 dark:bg-indigo-400 flex-shrink-0"></span>
                            <span>{bullet}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Education -->
          <div>
            <div class="flex items-center gap-3 mb-8 reveal">
              <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
                <!-- Graduation cap icon -->
                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">Education</h3>
            </div>

            <div class="relative">
              <!-- Timeline line -->
              <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500 via-purple-500 to-transparent"></div>

              <div class="space-y-10">
                {experienceContent.education.map((item, i) => (
                  <div class={`relative pl-14 reveal reveal-delay-${i + 1}`}>
                    <!-- Education dot -->
                    <div class="absolute left-0 top-1">
                      <div class="w-10 h-10 rounded-full bg-neutral-200 dark:bg-neutral-700 ring-4 ring-white dark:ring-neutral-950 shadow-sm flex items-center justify-center">
                        <svg class="w-4 h-4 text-neutral-500 dark:text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v6" />
                        </svg>
                      </div>
                    </div>

                    <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
                      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
                        <div>
                          <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
                            {item.degree}
                          </h3>
                          <p class="text-indigo-600 dark:text-indigo-400 font-semibold">
                            {item.school}
                          </p>
                          <p class="text-sm text-neutral-500 dark:text-neutral-500">{item.location}</p>
                        </div>
                        <span class="text-xs font-mono font-medium text-neutral-500 dark:text-neutral-400 tracking-wider whitespace-nowrap bg-neutral-100 dark:bg-neutral-800 px-3 py-1.5 rounded-full self-start flex items-center gap-1.5">
                          <svg class="w-3 h-3 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="2"/><path d="M16 2v4M8 2v4M3 10h18" stroke-width="2" stroke-linecap="round"/></svg>
                          {item.period}
                        </span>
                      </div>

                      {item.details && (
                        <p class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400 mb-2">
                          {item.details}
                        </p>
                      )}

                      {item.awards && (
                        <ul class="space-y-2 mt-3">
                          {item.awards.map((award) => (
                            <li class="flex gap-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                              <span class="text-amber-500 flex-shrink-0">🏆</span>
                              <span>{award}</span>
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════ PROJECTS SECTION ═══════════════ -->
      <section id="projects" class="py-24 sm:py-32 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-16">
            <div class="section-line mx-auto mb-4 reveal"></div>
            <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight reveal reveal-delay-1">
              Featured <span class="title-accent">Projects</span>
            </h2>
            <p class="mt-4 text-lg text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto reveal reveal-delay-2">
              {projectsContent.description}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {projectsContent.projects.map((project, i) => (
              <div class={`project-card group relative flex flex-col bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-white/5 rounded-3xl overflow-hidden transition-all duration-500 reveal reveal-delay-${(i % 4) + 1}`}>
                <!-- Large Image Container -->
                <div class="relative h-64 w-full overflow-hidden bg-neutral-100 dark:bg-neutral-950">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="project-image w-full h-full object-cover opacity-70 dark:opacity-60"
                    referrerpolicy="no-referrer"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-neutral-50 dark:from-neutral-900 via-neutral-50/40 dark:via-neutral-900/40 to-transparent"></div>

                  <!-- Overlay Links -->
                  <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noreferrer"
                      class="p-2.5 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-md rounded-full text-neutral-700 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors border border-neutral-200 dark:border-white/10 shadow-lg"
                    >
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.12 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                    </a>
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noreferrer"
                      class="p-2.5 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-md rounded-full text-neutral-700 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors border border-neutral-200 dark:border-white/10 shadow-lg"
                    >
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                </div>

                <!-- Content -->
                <div class="p-8 flex-1 flex flex-col">
                  <h3 class="text-2xl font-bold text-neutral-900 dark:text-white mb-4 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                    {project.title}
                  </h3>
                  <p class="text-neutral-500 dark:text-neutral-400 text-sm leading-relaxed mb-8 flex-1">
                    {project.description}
                  </p>

                  <!-- Tags -->
                  <div class="flex flex-wrap gap-2 mt-auto">
                    {project.tags.map((tag) => (
                      <span class="px-3 py-1 bg-neutral-200/60 dark:bg-white/5 border border-neutral-300 dark:border-white/10 rounded-full text-xs font-mono text-neutral-600 dark:text-neutral-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ OPEN SOURCE SECTION ═══════════════ -->
      <section class="py-24 sm:py-32 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-16">
            <div class="section-line mx-auto mb-4 reveal"></div>
            <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight reveal reveal-delay-1">
              Open <span class="title-accent">Source</span>
            </h2>
            <p class="mt-4 text-lg text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto reveal reveal-delay-2">
              Contributions to open source projects and communities.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {openSourceContent.contributions.map((contrib, i) => (
              <a
                href={contrib.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`skill-card group block p-6 rounded-2xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 shadow-sm reveal reveal-delay-${i + 1}`}
              >
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center">
                    <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.12 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{contrib.project}</h3>
                </div>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">{contrib.description}</p>
                <div class="flex flex-wrap gap-2">
                  {contrib.tags.map((tag) => (
                    <span class="px-2.5 py-1 text-xs font-mono bg-neutral-200/60 dark:bg-white/5 border border-neutral-300 dark:border-white/10 text-neutral-600 dark:text-neutral-300 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Scroll reveal script -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
        );

        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
